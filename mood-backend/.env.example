# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/mood_app?schema=public

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI 服务配置
ANTHROPIC_API_KEY=sk-ant-...

# 微信配置 (可选)
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_KEY=

# 阿里云短信配置 (可选)
ALIYUN_ACCESS_KEY=
ALIYUN_SECRET=

# 日志配置
LOG_LEVEL=info

# Sentry DSN (可选)
SENTRY_DSN=
